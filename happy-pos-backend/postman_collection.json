			"item": [
				{
					"name": "Login Cashier/Admin",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"const responseJson = pm.response.json();",
									"if (responseJson && responseJson.token) {",
									"    pm.collectionVariables.set(\"token\", responseJson.token);",
									"    console.log(\"JWT Token captured and saved successfully!\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"panbunheng58@gmail.com\",\n    \"password\": \"112233\"\n}",
							"options": {
								"raw": {
									"language": "json"
								}
							}
						},
						"url": {
							"raw": "{{baseUrl}}/auth/login",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"auth",
								"login"
							]
						},
						"description": "Exchanges cashier or admin credentials for a secure role-based JWT token."
					},
					"response": []
				}
			]
		},
