{
  "name": "happy-pos-backend",
  "version": "1.0.0",
  "description": "Production-grade Express + SQLite POS backend",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx src/db/seed.ts",
    "db:inspect": "tsx src/db/inspect.ts",
    "db:status": "tsx src/db/inspect.ts status",
    "db:products": "tsx src/db/inspect.ts products",
    "db:product": "tsx src/db/inspect.ts product",
    "db:orders": "tsx src/db/inspect.ts orders",
    "db:restock": "tsx src/db/inspect.ts restock",
    "db:add-product": "tsx src/db/inspect.ts add-product",
    "db:delete-product": "tsx src/db/inspect.ts delete-product",
    "db:sales-daily": "tsx src/db/inspect.ts sales-daily",
    "db:sales-monthly": "tsx src/db/inspect.ts sales-monthly"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^12.10.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.39.0",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.8.3",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.8",
    "@types/node": "^22.10.1",
    "drizzle-kit": "^0.30.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
